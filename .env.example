# Docker 环境变量配置示例
# 将本文件复制为 .env 并填写真实值

# MySQL root 密码
MYSQL_ROOT_PASSWORD=your_root_password_here

# Wiki 应用连接 MySQL 的密码（与 docker-compose 中 MYSQL_USER=wiki_user 对应）
MYSQL_PASSWORD=your_wiki_password_here

# JWT 签名密钥（请使用足够长的随机字符串，例如：openssl rand -base64 48）
JWT_SECRET=your_long_random_jwt_secret_here

# 应用对外暴露的端口（默认 3001）
APP_PORT=3001
