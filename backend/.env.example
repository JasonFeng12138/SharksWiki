# 服务端口
PORT=3001
NODE_ENV=development

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=wiki_user
DB_PASSWORD=wiki_password
DB_NAME=personal_wiki

# JWT 配置（请务必修改为复杂的随机字符串）
JWT_SECRET=change_this_to_a_long_random_secret_string_please
JWT_EXPIRES_IN=7d

# 文件存储路径（相对于后端工作目录或绝对路径）
DOCS_DIR=./docs
CONFIG_DIR=./config

# 生产模式下前端静态文件目录
FRONTEND_DIST=../frontend/dist
